[user]
    name = Robin Van den Broeck
    email = robin.broeck@gmail.com
[branch]
    sort = committerdate
[tag]
    sort = version:refname
[core]
    pager = less -F -X
    fsmonitor = true
    untrackedCache = true
[alias]
    tree = log --graph --decorate --pretty=oneline --abbrev-commit
    update-base = "!f() { \
        if git ls-remote --exit-code --heads origin main &>/dev/null; then \
            echo 'Fetching origin/main'; \
            git fetch origin main:main; \
        else \
            echo 'Fetching origin/master'; \
            git fetch origin master:master; \
        fi; \
    }; f"
    fixup = "!f() { \
        base=$(git show-ref --verify --quiet refs/remotes/origin/main && echo main || echo master); \
        git log $base.. --pretty=format:'%h %s' --no-merges | fzf | cut -c -9 | xargs -o git commit --fixup; \
    }; f"
    switch-branch = "!git b --sort=committerdate | fzf --no-sort --tac | xargs git checkout"
    sb = switch-branch
    b = branch
    bs = b --format='%(refname:short)'
    pushf = push --force-with-lease
    rbm = "!f() { \
        git update-base && git rebase -i $(git show-ref --verify --quiet refs/remotes/origin/main && echo main || echo master); \
    };"
[init]
    defaultBranch = main
[pull]
    twohead = ort
[diff]
    tool = vimdiff
    colorMoved = plain
    algorithm = histogram
    mnemonicPrefix = true
    renames = true
[merge]
    tool = vimdiff
[merge "npm-merge-driver"]
    name = automatically merge npm lockfiles
    driver = npx npm-merge-driver merge %A %O %B %P
[merge "yarn"]
    name = "yarn install"
    driver = yarn install
[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true
[rerere]
    enabled = true
[mergetool "vimdiff"]
    path = nvim
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[push]
    autoSetupRemote = true
